{
  "name": "investigate-client",
  "version": "1.0.0",
  "description": "m3's investigation tool — desktop SQL database client",
  "main": "main.js",
  "author": "m3",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win portable"
  },
  "build": {
    "appId": "com.m3.investigate",
    "productName": "investigate-client",
    "files": [
      "main.js",
      "preload.js",
      "db.js",
      "renderer/**/*",
      "node_modules/**/*"
    ],
    "asarUnpack": [
      "**/sql.js/dist/*.wasm"
    ],
    "win": {
      "target": "portable"
    },
    "portable": {
      "artifactName": "investigate-client.exe"
    }
  },
  "dependencies": {
    "mysql2": "^3.11.0",
    "pg": "^8.12.0",
    "sql.js": "^1.11.0"
  },
  "devDependencies": {
    "electron": "^31.3.0",
    "electron-builder": "^24.13.3"
  }
}
